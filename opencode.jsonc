{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "director",
  "skills": {
    "paths": [".agents/skills"]
  },
  "permission": {
    "*": "deny",
    "forge_*": "deny"
  },
  "mcp": {
    "forge_director": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "director" }, "enabled": true },
    "forge_source_researcher": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "source-researcher" }, "enabled": true },
    "forge_fact_curator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "fact-curator" }, "enabled": true },
    "forge_zhuji_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "zhuji-creator" }, "enabled": true },
    "forge_palette_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "palette-creator" }, "enabled": true },
    "forge_relationship_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "relationship-creator" }, "enabled": true },
    "forge_character_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "character-critic" }, "enabled": true },
    "forge_greetings_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "greetings-creator" }, "enabled": true },
    "forge_greetings_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "greetings-critic" }, "enabled": true },
    "forge_mode_conversion": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "mode-conversion" }, "enabled": true },
    "forge_card_import_analyst": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "card-import-analyst" }, "enabled": true },
    "forge_world_lore_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "world-lore-creator" }, "enabled": true },
    "forge_world_lore_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "world-lore-critic" }, "enabled": true },
    "forge_mvu_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "mvu-creator" }, "enabled": true },
    "forge_mvu_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "mvu-critic" }, "enabled": true },
    "forge_ejs_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "ejs-creator" }, "enabled": true },
    "forge_ejs_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "ejs-critic" }, "enabled": true },
    "forge_html_creator": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "html-creator" }, "enabled": true },
    "forge_html_critic": { "type": "local", "command": ["node", "packages/mcp-server/dist/index.js"], "cwd": ".", "environment": { "CARD_WORKSPACE_ROOT": ".", "CARD_WORKSPACE_AGENT_ID": "html-critic" }, "enabled": true }
  },
  "agent": {
    "build": {
      "description": "一般程式開發與維護；不得操作 Forge workflow。",
      "mode": "primary",
      "permission": {
        "*": "deny",
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "question": "allow",
        "todowrite": "allow",
        "task": { "*": "deny", "general": "allow", "explore": "allow" }
      }
    },
    "director": {
      "description": "訪談、調度、呈現四道使用者閘門與預覽發布結果。",
      "mode": "primary",
      "steps": 100,
      "prompt": "{file:./.opencode/prompts/director.md}\n\n# Skill Reference\n{file:./.agents/skills/director-orchestration/references/workflow-routing.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/director.yaml}",
      "permission": {
        "*": "deny",
        "read": { "*": "deny", "reference": "allow", "reference/**": "allow", "AI\\projects\\card-workspace\\reference": "allow", "AI\\projects\\card-workspace\\reference\\*": "allow" },
        "list": { "*": "deny", "reference": "allow", "reference/**": "allow" },
        "glob": { "*": "deny", "reference": "allow", "reference/**": "allow" },
        "grep": { "*": "deny", "reference": "allow", "reference/**": "allow" },
        "forge_director_*": "allow",
        "forge_director_workflow_approve_gate": "ask",
        "forge_director_workflow_reject_gate": "ask",
        "forge_director_source_research_approve": "ask",
        "skill": { "*": "deny", "director-orchestration": "allow" },
        "question": "allow",
         "task": { "*": "deny", "source-researcher": "allow", "fact-curator": "allow", "zhuji-creator": "allow", "palette-creator": "allow", "relationship-creator": "allow", "character-critic": "allow", "greetings-creator": "allow", "greetings-critic": "allow", "mode-conversion": "allow", "card-import-analyst": "allow", "world-lore-creator": "allow", "world-lore-critic": "allow", "mvu-creator": "allow", "mvu-critic": "allow", "ejs-creator": "allow", "ejs-critic": "allow", "html-creator": "allow", "html-critic": "allow" }
      }
    },
    "source-researcher": { "description": "在 Source Adaptation intake 執行模型聯網研究與已批准頁面擷取。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/source-researcher.md}\n\n# Skill Reference\n{file:./.agents/skills/source-research/references/source-policy.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/source-researcher.yaml}", "permission": { "*": "deny", "webfetch": "allow", "forge_source_researcher_*": "allow", "skill": { "*": "deny", "source-research": "allow" } } },
    "fact-curator": { "description": "從受控來源分片提出事實候選。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/fact-curator.md}\n\n# Skill Reference\n{file:./.agents/skills/fact-curation/references/extraction.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/fact-curator.yaml}", "permission": { "*": "deny", "forge_fact_curator_*": "allow", "skill": { "*": "deny", "fact-curation": "allow" } } },
    "zhuji-creator": { "description": "依 Blueprint 產生角色基礎文件與珠璣模式七模組 proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/zhuji-creator.md}\n\n# Skill References\n{file:./.agents/skills/zhuji-creation/references/generation-guide.md}\n\n{file:./.agents/skills/zhuji-creation/references/example-proposal.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-appearance.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-inner-nature.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-extension.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-trait-refinement.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-trait-dialogue.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-scene-dialogue.md}\n\n{file:./.agents/skills/zhuji-creation/references/module-self-introduction.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/zhuji-creator.yaml}", "permission": { "*": "deny", "forge_zhuji_creator_*": "allow", "skill": { "*": "deny", "zhuji-creation": "allow" } } },
    "palette-creator": { "description": "依 Blueprint 產生調色盤模式 proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/palette-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/palette-creation/references/generation-guide.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/palette-creator.yaml}", "permission": { "*": "deny", "forge_palette_creator_*": "allow", "skill": { "*": "deny", "palette-creation": "allow" } } },
    "relationship-creator": { "description": "依 Blueprint 與參與角色模組產生專案級關係 proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/relationship-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/relationship-creation/references/generation-guide.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/relationship-creator.yaml}", "permission": { "*": "deny", "forge_relationship_creator_*": "allow", "skill": { "*": "deny", "relationship-creation": "allow" } } },
    "character-critic": { "description": "唯讀審查角色 proposal 與正式產物。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/character-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/character-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/character-critic.yaml}", "permission": { "*": "deny", "forge_character_critic_*": "allow", "skill": { "*": "deny", "character-critique": "allow" } } },
    "greetings-creator": { "description": "產生專案級 primary、alternate 與 group-only greetings proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/greetings-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/greetings-creation/references/generation-guide.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/greetings-creator.yaml}", "permission": { "*": "deny", "forge_greetings_creator_*": "allow", "skill": { "*": "deny", "greetings-creation": "allow" } } },
    "greetings-critic": { "description": "唯讀審查 greetings 的玩家自由度與一致性。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/greetings-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/greetings-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/greetings-critic.yaml}", "permission": { "*": "deny", "forge_greetings_critic_*": "allow", "skill": { "*": "deny", "greetings-critique": "allow" } } },
    "mode-conversion": { "description": "提出完整目標模式與可追溯轉換 mapping。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/mode-conversion.md}\n\n# Skill Reference\n{file:./.agents/skills/mode-conversion/references/conversion-map.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/mode-conversion.yaml}", "permission": { "*": "deny", "forge_mode_conversion_*": "allow", "skill": { "*": "deny", "mode-conversion": "allow" } } },
    "card-import-analyst": { "description": "分析匯入卡片 envelope、passthrough 與 loss report。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/card-import-analyst.md}\n\n# Skill Reference\n{file:./.agents/skills/card-import-analysis/references/import-mapping.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/card-import-analyst.yaml}", "permission": { "*": "deny", "forge_card_import_analyst_*": "allow", "skill": { "*": "deny", "card-import-analysis": "allow" } } },
    "world-lore-creator": { "description": "依分類提出多維世界設定 proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/world-lore-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/world-lore-creation/references/generation-guide.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/world-lore-creator.yaml}", "permission": { "*": "deny", "forge_world_lore_creator_*": "allow", "skill": { "*": "deny", "world-lore-creation": "allow" } } },
     "world-lore-critic": { "description": "唯讀審查世界設定的衝突、依賴與觸發成本。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/world-lore-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/world-lore-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/world-lore-critic.yaml}", "permission": { "*": "deny", "forge_world_lore_critic_*": "allow", "skill": { "*": "deny", "world-lore-critique": "allow" } } },
     "mvu-creator": { "description": "依 task-bound Blueprint 產生 typed MVU plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/mvu-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/mvu-creation/references/generation.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/mvu-creator.yaml}", "permission": { "*": "deny", "forge_mvu_creator_*": "allow", "skill": { "*": "deny", "mvu-creation": "allow" } } },
     "mvu-critic": { "description": "唯讀審查 typed MVU plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/mvu-creator-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/mvu-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/mvu-creator-critic.yaml}", "permission": { "*": "deny", "forge_mvu_critic_*": "allow", "skill": { "*": "deny", "mvu-critique": "allow" } } },
     "ejs-creator": { "description": "依 approved MVU path registry 產生 typed EJS plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/ejs-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/ejs-creation/references/generation.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/ejs-creator.yaml}", "permission": { "*": "deny", "forge_ejs_creator_*": "allow", "skill": { "*": "deny", "ejs-creation": "allow" } } },
     "ejs-critic": { "description": "唯讀審查 typed EJS plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/ejs-creator-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/ejs-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/ejs-creator-critic.yaml}", "permission": { "*": "deny", "forge_ejs_critic_*": "allow", "skill": { "*": "deny", "ejs-critique": "allow" } } },
     "html-creator": { "description": "依 html-policy 產生 typed HTML plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/html-creator.md}\n\n# Skill Reference\n{file:./.agents/skills/html-creation/references/generation.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/html-creator.yaml}", "permission": { "*": "deny", "forge_html_creator_*": "allow", "skill": { "*": "deny", "html-creation": "allow" } } },
     "html-critic": { "description": "唯讀審查 typed HTML plugin proposal。", "mode": "subagent", "prompt": "{file:./.opencode/prompts/html-creator-critic.md}\n\n# Skill Reference\n{file:./.agents/skills/html-critique/references/negative-rules.md}\n\n{file:./workflow/personalities/runtime-instructions.md}\n\n# Shared Personality Baseline\n{file:./workflow/personalities/base-adult.yaml}\n\n# Agent Personality Override\n{file:./workflow/personalities/html-creator-critic.yaml}", "permission": { "*": "deny", "forge_html_critic_*": "allow", "skill": { "*": "deny", "html-critique": "allow" } } }
  }
}
